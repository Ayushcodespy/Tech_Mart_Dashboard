GROCERY_APP_NAME=TechMart API
GROCERY_STORE_NAME=TechMart
GROCERY_DEBUG=false
# GROCERY_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=no-verify
GROCERY_DATABASE_SSL=true
GROCERY_DATABASE_SCHEMA=ecommerce_for_tcs_theegatewe
GROCERY_JWT_SECRET_KEY=replace-with-a-long-random-production-secret
GROCERY_JWT_ALGORITHM=HS256
GROCERY_ACCESS_TOKEN_EXPIRE_MINUTES=15
GROCERY_REFRESH_TOKEN_EXPIRE_DAYS=7
GROCERY_CORS_ORIGINS=["https://your-user-app-domain.com","https://your-admin-panel-domain.com"]
GROCERY_PORT=8000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=TechMart
SMTP_USE_TLS=false
SMTP_USE_SSL=true
PASSWORD_RESET_CODE_EXPIRE_MINUTES=15
